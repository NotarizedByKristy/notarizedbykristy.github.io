function toggleFaq(btn){
  const icon=btn.querySelector('.faq-icon'),answer=btn.nextElementSibling,isOpen=answer.classList.contains('open');
  document.querySelectorAll('.faq-a.open').forEach(a=>a.classList.remove('open'));
